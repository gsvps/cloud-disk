{
  "name": "cloud-disk",
  "version": "1.0.0",
  "description": "基于 Cloudflare Workers 的轻量级个人网盘，D1 + R2 + KV",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/styles.css --minify",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "deploy": "npm run db:migrate && wrangler deploy",
    "deploy:cloudflare": "npm run build && npm run deploy",
    "typecheck": "tsc --noEmit"
  },
  "cloudflare": {
    "label": "CloudDisk",
    "products": ["Workers", "D1", "R2"],
    "bindings": {
      "DB": {
        "description": "D1 数据库，存储用户与文件元数据。默认名称：`cloud-disk`"
      },
      "KV": {
        "description": "KV 命名空间，存储登录会话。默认名称：`cloud-disk`（与 D1 同名，与 R2 不可同名）"
      },
      "R2": {
        "description": "R2 存储桶，存储上传文件。默认名称：`cloud-disk-files`"
      },
      "APP_NAME": {
        "description": "应用显示名称，默认 `CloudDisk` 即可，一般无需修改"
      }
    }
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "drizzle-kit": "^0.31.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.0"
  }
}
